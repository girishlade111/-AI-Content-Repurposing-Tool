generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  credits   Int      @default(3)
  tier      String   @default("free")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      RepurposingJob[]
  templates Template[]
  analytics Analytics[]
  libraryItems ContentLibrary[]
  bulkJobs  BulkJob[]
  socialAccounts SocialAccount[]
}

model RepurposingJob {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  inputType    String
  inputContent String
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  completedAt  DateTime?
  content      GeneratedContent[]
  analytics    Analytics[]
  libraryItem  ContentLibrary?
}

model GeneratedContent {
  id        String   @id @default(cuid())
  jobId     String
  job       RepurposingJob @relation(fields: [jobId], references: [id])
  type      String
  platform  String?
  content   String
  createdAt DateTime @default(now())
}

model Template {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  description String?
  category    String   @default("custom")
  systemPrompt String
  tone        String   @default("professional")
  isDefault   Boolean  @default(false)
  useCount    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Analytics {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  jobId       String?
  job         RepurposingJob? @relation(fields: [jobId], references: [id])
  eventType   String
  eventData   String?
  createdAt   DateTime @default(now())
}

model ContentLibrary {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  jobId       String?  @unique
  job         RepurposingJob? @relation(fields: [jobId], references: [id])
  title       String
  folder      String   @default("default")
  tags        String   @default("[]")
  isFavorite  Boolean  @default(false)
  contentType String?
  preview     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BulkJob {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  name        String
  items       String   @default("[]")
  status      String   @default("pending")
  progress    Int      @default(0)
  totalItems  Int      @default(0)
  completedItems Int   @default(0)
  results     String   @default("[]")
  createdAt   DateTime @default(now())
  completedAt DateTime?
}

model SocialAccount {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  platform    String
  accessToken String
  refreshToken String?
  accountName String?
  accountId   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ScheduledPost {
  id          String   @id @default(cuid())
  userId      String
  accountId   String
  content     String
  platform    String
  scheduledFor DateTime
  status      String   @default("scheduled")
  postId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}